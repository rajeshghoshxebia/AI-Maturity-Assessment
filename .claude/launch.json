{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Backend",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "backend",
      "port": 8000,
      "autoPort": false
    }
  ,
    {
      "name": "aura-divine-v2",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "C:\\personal\\AuraDivineV2\\frontend", "-p", "4200", "--no-clipboard"],
      "port": 4200
    }
  ]
}
