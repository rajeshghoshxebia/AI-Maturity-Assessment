# Database — Railway provides DATABASE_URL automatically; replace postgresql:// with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Azure AD (leave blank to keep dev-mode bypass active)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_JWKS_URI=

# Azure Communication Services (email for survey invitations)
ACS_CONNECTION_STRING=
ACS_SENDER_EMAIL=no-reply@xebia.com

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Environment
APP_ENV=production
LOG_LEVEL=INFO
