DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_maturity
SECRET_KEY=change-me-in-production

# Azure AD
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_JWKS_URI=https://login.microsoftonline.com/{tenant_id}/discovery/v2.0/keys

# Azure Communication Services (survey invites)
ACS_CONNECTION_STRING=
ACS_SENDER_EMAIL=no-reply@yourdomain.com

APP_ENV=development
LOG_LEVEL=INFO
